{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "include": [
    "src/**/*",
    "src/**/*.svelte",
    "src/**/*.d.ts"
  ],
  "compilerOptions": {
    "paths": {
      "$core": [
        "./src/core/index.ts"
      ],
      "$utils": [
        "./src/shared/utils/index.ts"
      ],
      "$features/*": [
        "./src/features/*"
      ],
      "$components": [
        "./src/shared/components/index.ts"
      ],
      "$wasm/*": [
        "./src-wasm/pkg/*"
      ]
    },
    "allowJs": true,
    "moduleResolution": "bundler",
    "target": "es2022",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
  }
}
