{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "include": [
    "src/**/*",
    "src/**/*.svelte",
    "src/**/*.d.ts"
  ],
  "compilerOptions": {
    "allowJs": true,
    "moduleResolution": "bundler",
    "target": "es2022",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
  }
}
