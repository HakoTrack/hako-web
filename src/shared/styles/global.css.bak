@import "tailwindcss";
@plugin "tailwindcss-animate";

:root {
  /* Theme Base */
  --bg: #0b1622;
  --fg: #9fadbd;
  --accent: #3db4f2;
  --surface: #151f2e;
  --surface-dim: #0b1622;
  --surface-elevated: #2b2d42;
}

body {
  font-family: 'Inter', sans-serif;
  background-color: var(--bg);
  color: var(--fg);
}

.bg-card { background-color: var(--surface); }
.bg-nav { background-color: var(--surface-elevated); }
.text-accent { color: var(--accent); }
.bg-accent { background-color: var(--accent); }
.border-accent { border-color: var(--accent); }

/* Firefox Sleek Scrollbar */
* {
  scrollbar-width: thin;
  scrollbar-color: var(--accent) var(--surface-elevated);
}

/* Chromium Minimalist Scrollbar */
::-webkit-scrollbar {
  width: 10px;
}

::-webkit-scrollbar-button {
  display: none;
}

::-webkit-scrollbar-track {
  background: var(--surface-elevated);
}


::-webkit-scrollbar-thumb {
  background: var(--accent);
  border-radius: 5px;
  border: 2px solid var(--surface-elevated);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent);
}


.nav-link:hover { color: #edf1f5; }
.tab-active { border-bottom: 3px solid var(--accent); }

.heatmap-cell { width: 12px; height: 12px; border-radius: 2px; }

@keyframes unroll {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.animate-unroll { animation: unroll 0.1s ease-out forwards; }

/* Activity Levels mapped to the new palette */
.level-0 { background-color: var(--surface-dim); } /* No activity */
.level-1 { background-color: #7fa563; }           /* Low activity */
.level-2 { background-color: #8bb972; }             /* Medium */
.level-3 { background-color: #99b782; }          /* High activity */
.level-4 { background-color: var(--accent); }       /* Peak activity */

.media-card:hover .overlay { opacity: 1; }
.media-card .overlay {
  opacity: 0;
  transition: opacity 0.2s ease;
}

.badge-genre {
  background-color: rgba(59, 130, 246, 0.1); /* blue-500/10 */
  color: #60a5fa; /* blue-400 */
  font-size: 10px;
  padding: 0.125rem 0.5rem;
  border-radius: 0.25rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
